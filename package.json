{
  "name": "safe-ugc-ui",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest",
    "test:clean-checkout": "pnpm clean && pnpm --filter @safe-ugc-ui/demo typecheck && pnpm --filter @safe-ugc-ui/demo build",
    "test:contracts": "pnpm --filter @safe-ugc-ui/validator test:contracts && pnpm --filter @safe-ugc-ui/react test:contracts",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "vite@>=6.0.0 <6.4.2": ">=6.4.2"
    }
  }
}
