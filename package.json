{
  "name": "safe-ugc-ui",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest",
    "test:clean-checkout": "pnpm clean && pnpm test:run && pnpm --filter @safe-ugc-ui/demo typecheck && pnpm --filter @safe-ugc-ui/demo build",
    "test:contracts": "pnpm test:contracts:clean-workspace",
    "test:contracts:packages": "pnpm --filter @safe-ugc-ui/validator test:contracts && pnpm --filter @safe-ugc-ui/react test:contracts",
    "test:contracts:clean-workspace": "pnpm clean && pnpm test:contracts:packages && pnpm --filter @safe-ugc-ui/demo typecheck",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "release:pack-check": "node scripts/release-pack-check.mjs",
    "release:check": "pnpm format:check && pnpm test:contracts && pnpm test:clean-checkout && pnpm build && pnpm release:pack-check && pnpm -r exec tsc --noEmit && pnpm audit && pnpm test:coverage",
    "clean": "pnpm -r exec rm -rf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "prettier": "^3.8.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "postcss@>=8.0.0 <8.5.10": ">=8.5.10",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "vite@>=6.0.0 <6.4.2": ">=6.4.2"
    }
  }
}
